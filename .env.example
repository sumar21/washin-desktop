# ── Microsoft Graph (app-only / client credentials) ──────────────────────────
# Registrar una App en Entra ID (Azure AD) con permisos de aplicación
# Sites.ReadWrite.All (SharePoint) y Mail.Send (envío de emails). Estos valores
# van SOLO en el backend (funciones serverless de Vercel), nunca en el cliente.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── SharePoint (base de datos: sitio "Nueva") ────────────────────────────────
# Opcional: el backend resuelve el site ID en runtime (GET /sites/sumardigital.
# sharepoint.com:/sites/Nueva) y lo cachea, así que esta variable no hace falta.
# Dejala vacía salvo que quieras forzar un valor específico.
SHAREPOINT_SITE_ID=

# ── Sesión (backend) ──────────────────────────────────────────────────────────
# Secreto para firmar la cookie de sesión (HMAC). Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Nunca reutilizar el mismo valor entre entornos (local/preview/producción).
SESSION_SECRET=

# ── Email transaccional ──────────────────────────────────────────────────────
# Buzón (UPN) desde el que se envían los correos vía Graph sendMail.
EMAIL_ADDRESS=
